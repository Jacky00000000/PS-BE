# =========================
# Development environment
# Copy to .env and adjust values
# =========================

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True to connect to Render PostgreSQL from local machine
USE_PROD_DATABASE=False

# PostgreSQL (matches docker-compose defaults)
DATABASE_NAME=ps_be
DATABASE_USER=ps_be
DATABASE_PASSWORD=ps_be
DATABASE_HOST=localhost
DATABASE_PORT=5433

# Optional: Render provides DATABASE_URL automatically when Postgres is linked
# DATABASE_URL=postgres://user:password@host:5432/dbname

# DeepSeek API (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60

# Frontend CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# =========================
# Render PostgreSQL (Production)
# Use External URL when connecting from your local machine
# Use Internal URL when Web Service runs on Render (same private network)
# =========================
DATABASE_HOST_PROD=your-host.singapore-postgres.render.com
DATABASE_PORT_PROD=5432
DATABASE_NAME_PROD=your-database-name
DATABASE_USER_PROD=your-username
DATABASE_PASSWORD_PROD=your-password
DATABASE_URL_INTERNAL_PROD=postgresql://user:password@internal-host/dbname
DATABASE_URL_EXTERNAL_PROD=postgresql://user:password@external-host.singapore-postgres.render.com/dbname
